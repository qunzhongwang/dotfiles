# Dotfiles environment configuration
# Copy to .env and fill in your values: cp .env.example .env
# Works with: source .env, docker run --env-file .env, or bare env vars (vast.ai/autodl UI)

GITHUB_TOKEN=
HF_TOKEN=
WANDB_API_KEY=

# Optional: base64-encoded Ed25519 private key for SSH auth + git signing
# Generate: cat ~/.ssh/id_ed25519 | base64 -w0
SSH_PRIVATE_KEY=

# Optional: GitHub username for cloning private repos (defaults to qunzhongwang)
GITHUB_USER=

# Optional: persistent disk path for cache redirect (Phase 2)
# After setting this, run: bash ~/dotfiles/setup-disk.sh
DISK=

# Optional: disk layout mode — "symlink" (HPC /scratch) or "workspace" (Docker /workspace)
# symlink: ~/.cache -> $DISK/.cache (default)
# workspace: everything lives under $DISK directly, $HOME is config-only
DISK_MODE=

# Optional: workspace directory (defaults to ~/wp, or $DISK/wp in workspace mode)
WORKSPACE_DIR=
